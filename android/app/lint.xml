<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!--
      Generated UniFFI bindings (src/main/java/uniffi/**) are regenerated by uniffi-bindgen, so
      they can't carry annotations. Their java.lang.ref.Cleaner usage is runtime-guarded
      (Class.forName(...) with a JNA-cleaner fallback for API < 33), making NewApi a false
      positive here. ktlint already excludes the same path (see app/build.gradle.kts).
    -->
    <issue id="NewApi">
        <ignore regexp="uniffi/sverto_core" />
    </issue>
</lint>
